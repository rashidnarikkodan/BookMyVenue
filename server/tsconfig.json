{
  "compilerOptions": {
    "target": "ES2023",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "paths": {
      "@/*": ["./src/*"]
    },

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
